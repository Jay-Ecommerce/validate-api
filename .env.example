# Copy to .env for local Docker/self-host use. Never commit the real .env file.

# The secret RapidAPI injects as X-RapidAPI-Proxy-Secret on every proxied request.
# Get this value from your RapidAPI provider dashboard after creating the API listing.
RAPIDAPI_PROXY_SECRET=changeme

# Set to "true" only for local development to bypass the RapidAPI proxy check.
# Must be "false" (or unset) in any publicly reachable deployment.
ALLOW_DIRECT_ACCESS=false

PORT=8787
